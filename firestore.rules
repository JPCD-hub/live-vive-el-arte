rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Membership is provisioned outside the app. An authenticated user may only
    // read its own membership document in order to determine access.
    match /admins/{userId} {
      allow get: if signedIn() && request.auth.uid == userId;
      allow list, create, update, delete: if false;
    }

    // This is the only public collection. A token is an unguessable document ID;
    // listing remains prohibited, and ticket documents contain no contact data.
    match /tickets/{ticketToken} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /people/{personId} {
      allow read, write: if isAdmin();
    }

    match /events/{eventId} {
      allow read, write: if isAdmin();
    }

    match /checkins/{checkinId} {
      allow read, write: if isAdmin();
    }

    match /benefits/{benefitId} {
      allow read, write: if isAdmin();
    }
  }
}
